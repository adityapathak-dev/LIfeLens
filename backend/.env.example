# ─── LLM Provider ────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to: openai | groq | anthropic
LLM_PROVIDER=openai

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Anthropic Claude fallback
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://lifelens.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Security ─────────────────────────────────────────────────────────────────
# A long random secret to protect the /api/metrics endpoint.
# Generate one with: openssl rand -hex 32
METRICS_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
